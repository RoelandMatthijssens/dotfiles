#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў в ҠвЎҒв  вЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЎңвў в Ғв Җвў«вЎ‘вў„вЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЎӨв җв ‘в Ҷв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЎҮвўёв Җвў·в Җв івЈ„в Ҹв ўвЈҖвЎҖвўҖв Җв Җв ҖвўҖв ҙв Ӯвў©в ҸвўҖвЎ”в Җв Җв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҮв ҲвЈҮв јвЈҮв Җвў№в ҹв Ғв Ғв Ҳв үв ‘в ғв ’вЈ·вЈҒвЎ”в Ғв ҖвЈјвўҒв ҖвЎҢв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈёв ҖвўёвЎ„вўҳвЎҰв Ҡв Җв Җв Җв Җв Җв Җв Җв Җв ӣвЎҸв Җв ҖвЈёв »вЎјвў в Ғв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҲвЎҸв Җв ҖвўҲв һв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ўвЈҙвўҒв јв ҮвўҖвЎҖв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвўҳв ұв ӨвўІв Җв ‘вЈ„вЈ°в —в Ҡв үв үв ұвЎҖв Җв Җв Җвў в ҙв ”вўӨвЈҖв Җв ҷвў…в Җв ҖвЈҖв Үв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ӯв ”в Җв Җв ҖвЈҪв ғвўҖвЈҙвЈ¶вЈ„в Җв Үв Җв Җв Җвў§в ҖвЈҖвЈ„в Җв Ғвў„в ҲвЈўв ”в Җв Җв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв ҖвЈҖвЎ в Өв ӨвЈҖвЎҖв Җв Җв ҖвЈјв Үв ҖвЎҲвЈҝвЈҝвЈҝвЎӨв –в ’в ўвў„вЈёвЈҝвЈ»вЈҝвў·в Җв ҖвўӮв ұвЎҮв Җв Җв Җв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв ҖвЎ в –в үв Җв Җв Җв Җв Җв үв “вў„в Җвўҝв Җв ҖвЈҝвўҝвЈҝв Ҹв ҖвЈӨвЈӨвЎҖв Җв ҷвЈҝвЈҝвЈҝвЎҝв Җв Җвўёв ҖвўҮв Җв Җв Җв Җв Җв Җв Җв Җ
#                          в Җв ҖвЎ в Ҡв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈүвЈ©вЈҝвЎәвўівЎҖв ҳв ҝвўҝвЎ„в ҖвЈЁвЈҚв Җв Җв ҖвЈҝвЈҫв ҹв Ғв ҖвЎ в ҠвўҖв һв Җв Җв Җв Җв Җв Җв Җв Җ
#                          в ҖвЎңв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ӣв Ғв ҖвЈ№в Җв Ҳвў»вЈөвЈҰвЈ„в үв ІвЈ¬вЈҘвЎӨв Җв ҡв Јв Өв Өвў’вЈҠвЈ в ”вўӣв –в Җв „вЎҖв Җв Җв Җв Җв Җ
#                          в °в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖв Үв ҖвўҖвЈјвЎҝв Ҳв Ҳв үв ӣв ӣв ӣв ӣв ӣв ’в ’в ӣв ӣв ӣв »вЎҝв „в Ҳв ўв ‘вў„в Җв Җв Җв Җв Җв Җ
#                          вЎҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў в Ҡв Җв ҖвўёвЎҹвЎ…в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈёвЎҹвў„в Җв Җв Җв Җв Ғв Җв Җв Җв Җв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҸв Җв Җв ҖвўёвЈҝв Үв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҳвЎҝвў·в Җв ЈвЎҖв Җв Җв Җв Җв Җв Җв Җв Җ
#                          вЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв івЎҖв Җв ҖвЎёв —вўҖвЎҖв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈӨв һв Ғв ёвЎҶв Җв ұвЎҖв Җв Җв Җв Җв Җв Җв Җ
#                          вўҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ’вўӨвЈҮв Җв Җв івЈ”в Җв Җв Җв Җв Җв Җв ҖвЈҙв ҹв Ғв Җв Җв ҖвЈҝв Җв Җв ӣвў„в Җв Җв Җв Җв Җв Җ
#                          в ҳвЈҶв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҖв Җв Җв ҖвЎ в ғвўёвЎҶв Җв Җв Ҳв ·вЈҰв Җв ҖвЈҖв °в ҹвЈЎвЎӨвЈӨвЈ„вЎҖвў вЈҮв Җв Җв Җв Җвў»в ‘в  вЎҖв Җв Җ
#                          в Җв ҷвЈ§в Җв Җв Җв Җв Җв ҖвЎ®в ҹвўҪвўӣв Ғвўұв ғвЈ вЎһвЈҝвЈ„вЈҙв Ӣв үвў»вЎ·вўҙв ғв Җвўёв Ғв Җв Җв Җв ҷвў¶вЎүв ҷв ІвЈ„в Җв Җвўғв Җв ҲвўЈв Җ
#                          в Җв Җв Җв ўвЈҖв Җв Җв Җв Җв Җв әвЎӯв Ҹв  вЈҫвЈҙвЈҝвЈ·вЈҝв Ӣв Ӣв Җв ҖвЈ»вЎҮвўёв Җв Җв ҳвЈ§в Җв Җв Җвў°вЎҲвЈ·в Җв Җв ҲвўҝвЈ„вўёв Җв ҖвўёвЎҮ
#                          в Җв Җв Җв Җв Ҳв івўҖвЎҖв Җв Җв ¬вў§вЎҰв ҖвўівЈҫвўҜвЈҪвЈҝв Җв Җв ҖвЈ°вЎҹв ҖвЈҝв Җв Җв Җв ёвЈ§в Җв Җв Ҳв “в ӣв Җв Җв Җв °вЈҝв Ҹв Җв ҖвЈҫв Ү
#                          в Җв Җв Җв Җв ҖвўҖвЈҖвЈҖвЈүвЈ©вЈ·вЈҝвЈ·вЈҰвЈјвЈҝвЎҹвўүвЎҮв Җв Җвў°вЎҹв ҒвўҖвЎҸв Җв Җв Җвў вЈҝвЈ§вЎҖв Җв Җв Җв Җв ҖвЈҖвЈјвЈ§вЈӨвЎ¶в ҫв Үв Җ
#                          в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв үв үв үв үв ӣв ӣв “в ҝв Ұв ¶в ҝв ·в ҫв ҝв ҝв ¶в ¶в ¶в ҝв ҝв ҝв ·в ¶в ¶в ҝв ҹв ӣв үв үв үв үв Җв Җв Җв Җ
#
#  ,ggggggggggg,                        ,ggggggggggg,
# dP"""88""""""Y8,                   8IdP"""88""""""Y8,                            8I
# Yb,  88      `8b                   8IYb,  88      `8b                            8I
#  `"  88      ,8P                   8I `"  88      ,8P                            8I
#      88aaaad8P"                    8I     88aaaad8P"                             8I
#      88""""Yb,     ,ggg,     ,gggg,8I     88""""",gggg,gg   ,ggg,,ggg,     ,gggg,8I    ,gggg,gg
#      88     "8b   i8" "8i   dP"  "Y8I     88    dP"  "Y8I  ,8" "8P" "8,   dP"  "Y8I   dP"  "Y8I
#      88      `8i  I8, ,8I  i8'    ,8I     88   i8'    ,8I  I8   8I   8I  i8'    ,8I  i8'    ,8I
#      88       Yb, `YbadP' ,d8,   ,d8b,    88  ,d8,   ,d8b,,dP   8I   Yb,,d8,   ,d8b,,d8,   ,d8b,
#      88        Y8888P"Y888P"Y8888P"`Y8    88  P"Y8888P"`Y88P'   8I   `Y8P"Y8888P"`Y8P"Y8888P"`Y8
# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"
path=('/Users/enermis/go/bin' '/Users/enermis/bin' $path)

zmodload zsh/zprof


# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="robbyrussell"

# Set list of themes to pick from when loading at random
# Setting this variable when ZSH_THEME=random will cause zsh to load
# a theme from this variable instead of looking in $ZSH/themes/
# If set to an empty array, this variable will have no effect.
# ZSH_THEME_RANDOM_CANDIDATES=( "robbyrussell" "agnoster" )

# Uncomment the following line to use case-sensitive completion.
# CASE_SENSITIVE="true"

# Uncomment the following line to use hyphen-insensitive completion.
# Case-sensitive completion must be off. _ and - will be interchangeable.
# HYPHEN_INSENSITIVE="true"

# Uncomment one of the following lines to change the auto-update behavior
# zstyle ':omz:update' mode disabled  # disable automatic updates
# zstyle ':omz:update' mode auto      # update automatically without asking
# zstyle ':omz:update' mode reminder  # just remind me to update when it's time

# Uncomment the following line to change how often to auto-update (in days).
# zstyle ':omz:update' frequency 13

# Uncomment the following line if pasting URLs and other text is messed up.
# DISABLE_MAGIC_FUNCTIONS="true"

# Uncomment the following line to disable colors in ls.
# DISABLE_LS_COLORS="true"

# Uncomment the following line to disable auto-setting terminal title.
# DISABLE_AUTO_TITLE="true"

# Uncomment the following line to enable command auto-correction.
# ENABLE_CORRECTION="true"

# Uncomment the following line to display red dots whilst waiting for completion.
# You can also set it to another string to have that shown instead of the default red dots.
# e.g. COMPLETION_WAITING_DOTS="%F{yellow}waiting...%f"
# Caution: this setting can cause issues with multiline prompts in zsh < 5.7.1 (see #5765)
# COMPLETION_WAITING_DOTS="true"

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# You can set one of the optional three formats:
# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# or set a custom format using the strftime function format specifications,
# see 'man strftime' for details.
HISTFILE="$HOME/.zsh_history"
HIST_STAMPS="yyyy-mm-dd"
HISTSIZE=10000000
SAVEHIST=$HISTSIZE
setopt BANG_HIST                 # Treat the '!' character specially during expansion.
setopt INC_APPEND_HISTORY        # Write to the history file immediately, not when the shell exits.
setopt SHARE_HISTORY             # Share history between all sessions.
setopt HIST_EXPIRE_DUPS_FIRST    # Expire duplicate entries first when trimming history.
setopt HIST_IGNORE_DUPS          # Don't record an entry that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS      # Delete old recorded entry if new entry is a duplicate.
setopt HIST_FIND_NO_DUPS         # Do not display a line previously found.
setopt HIST_IGNORE_SPACE         # Don't record an entry starting with a space.
setopt HIST_SAVE_NO_DUPS         # Don't write duplicate entries in the history file.
setopt HIST_REDUCE_BLANKS        # Remove superfluous blanks before recording entry.
setopt HIST_VERIFY               # Don't execute immediately upon history expansion.


# Would you like to use another custom folder than $ZSH/custom?
# ZSH_CUSTOM=/path/to/new-custom-folder

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(git tmux rbenv kubectl gradle direnv)

# Tmux
ZSH_TMUX_AUTOSTART=true

source $ZSH/oh-my-zsh.sh

# User configuration

# export MANPATH="/usr/local/man:$MANPATH"

# You may need to manually set your language environment
# export LANG=en_US.UTF-8

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# export NVM_DIR="$HOME/.nvm"
#
# if [ -s "/opt/homebrew/opt/nvm/nvm.sh" ]; then
#   nvm_lazy_load() {
#     unset -f nvm_lazy_load
#     [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
#     [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
#     nvm "$@"
#   }
#
#   alias nvm="nvm_lazy_load"
#   alias node="nvm_lazy_load node"
#   alias npm="nvm_lazy_load npm"
#   alias yarn="nvm_lazy_load yarn"
# fi

export NVM_DIR="$HOME/.nvm"

nvm_lazy_load() {
  unset -f nvm_lazy_load node npm yarn nvm

  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
  [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

  command "$1" "${@:2}"
}

nvm()  { nvm_lazy_load nvm "$@"; }
node() { nvm_lazy_load node "$@"; }
npm()  { nvm_lazy_load npm "$@"; }
yarn() { nvm_lazy_load yarn "$@"; }

alias python="python3"
alias htop='btop'
alias oldvim='command vim'
alias vim='nvim'

# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"
export DISABLE_SPRING=true

# >>> conda lazy initialize >>>
conda() {
  unset -f conda
  if [ -f "/Users/enermis/miniconda3/etc/profile.d/conda.sh" ]; then
    . "/Users/enermis/miniconda3/etc/profile.d/conda.sh"
    conda "$@"
  else
    echo "conda script not found" >&2
    return 1
  fi
}
# <<< conda lazy initialize <<<

# Direnv
eval "$(direnv hook zsh)"

export GOPRIVATE=github.com/belgianmobileid/nova-utils

function cat_todo() {
  if [ -f "./todo.md" ] && grep -qve '^\s*$' "./todo.md"; then
    echo "--- TODO for $(pwd) ---"
    cat "./todo.md"
    echo "------------------------"
    echo
  fi
}

function show_todos() {
  if command -v kan &>/dev/null
  then
    if [[ "$PWD" == "$HOME" ]]
    then
      kan list
    else
      cat_todo
    fi
  else
    cat_todo
  fi
}

function chpwd() {
  show_todos
}

if [[ -z "$SKIP_WELCOME" ]]; then
    cat ~/.zsh_welcome
    show_todos
else
    zprof | head -n 20
fi


# Created by `pipx` on 2025-06-20 13:50:46
export PATH="$PATH:/Users/enermis/.local/bin"

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

eval "$(pyenv init -)"
