#!/bin/bash
RED='\033[0;31m'
GREEN='\033[1;32m'
NC='\033[0m' # No Color

printf "${RED}I no longer want to support ngrok, i've switched to ${GREEN}pagekite${RED} instead${NC}\n"
printf "for install instructions go here: https://pagekite.net/support/quickstart/\n"
printf "\n"
printf "${GREEN}~>${NC} pagekite <port of local server> enermis.pagekite.me\n"
printf "\n"
